# PAI Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit the .env file to version control

# ============================================================================
# CLAUDE CODE API SERVER (for remote access via Telegram/n8n)
# ============================================================================
# Port for the Claude Code API server
CLAUDE_API_PORT=3001

# API key for authentication (generate with: openssl rand -hex 32)
# This protects your local Claude Code instance from unauthorized access
CLAUDE_API_KEY=your_secure_api_key_here

# ============================================================================
# RESEARCH AGENTS - API Keys Required
# ============================================================================

# Perplexity API (perplexity-researcher agent)
# Get your key from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google Gemini API (gemini-researcher agent)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# xAI Grok API (grok-researcher agent - research synthesis & content ideation)
# Get your key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Claude API is built-in to Claude Code (no key needed for claude-researcher)

# ============================================================================
# AI IMAGE/VIDEO GENERATION (Optional)
# ============================================================================

# Replicate API (for Flux, Sora, etc.)
# Get your key from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# OpenAI API (for GPT-Image-1, Sora billing)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================================
# ADDITIONAL SERVICES (Optional)
# ============================================================================

# Telegram Bot (for PAI status notifications and alerts)
# Create a bot: https://t.me/botfather
# 1. Send /newbot to @BotFather
# 2. Choose a name and username for your bot
# 3. Copy the bot token below
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your Chat ID: https://t.me/userinfobot
# 1. Send /start to @userinfobot
# 2. Copy the ID number it sends back
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# BrightData (for web scraping with CAPTCHA bypass)
# Get your key from: https://brightdata.com
BRIGHTDATA_API_KEY=your_brightdata_api_key_here

# Discord Bot (for server administration via DiscordAdmin skill)
# Create a bot: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_server_id_here

# GitHub Personal Access Token (for GitHub MCP plugin)
# Generate at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# Notion API Token (for Notion MCP integration)
# Create an integration: https://www.notion.so/my-integrations
NOTION_API_TOKEN=your_notion_api_token_here

# Alpaca Markets (for Trading skill - paper trading)
# Sign up at: https://alpaca.markets
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# n8n Workflow Automation (for n8n MCP server)
# Self-hosted n8n instance
N8N_API_URL=your_n8n_url_here
N8N_API_KEY=your_n8n_api_key_here

# Hostinger API (for VPS management via MCP)
# Get from Hostinger dashboard
HOSTINGER_API_TOKEN=your_hostinger_api_token_here

# Clerk (for auth in web projects)
# Get from: https://dashboard.clerk.com
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ============================================================================
# CRYPTO TRADING (Polymarket BTC 15m Monitor)
# ============================================================================
# No API keys required -- uses public endpoints (Chainlink, Polymarket, Binance)
# Config is in: ~/.claude/skills/CryptoTrading/tools/polymarket-monitor/.env
# Polygon RPC upgrade (optional): Get a dedicated endpoint from Alchemy/Infura

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env file to git
# 2. Add .env to .gitignore
# 3. Use environment-specific values for production
# 4. Rotate keys regularly
# 5. Use minimum required permissions for each API key
