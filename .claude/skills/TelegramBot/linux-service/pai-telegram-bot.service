[Unit]
Description=PAI Telegram Bot - Full PAI access via Telegram
Documentation=https://github.com/your-repo/PAI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/home/youruser/.bun/bin/bun /home/youruser/.claude/skills/TelegramBot/tools/Server.ts
Restart=always
RestartSec=10

# Environment
Environment=PAI_DIR=/home/youruser/.claude
Environment=HOME=/home/youruser

# Logging
StandardOutput=append:/home/youruser/.claude/logs/telegram-bot.log
StandardError=append:/home/youruser/.claude/logs/telegram-bot.log

# Working directory
WorkingDirectory=/home/youruser/.claude/skills/TelegramBot/tools

[Install]
WantedBy=default.target
